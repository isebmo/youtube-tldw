{
    "manifest_version": 2,
    "name": "YouTube TLDW;",
    "version": "1.0",
    "description": "Summarize YouTube videos using AI API",
    "browser_specific_settings": {
        "gecko": {
            "id": "youtube-tldw@sebastienmouret.com",
            "strict_min_version": "109.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "permissions": [
        "activeTab",
        "storage",
        "https://*.youtube.com/*",
        "https://generativelanguage.googleapis.com/*",
        "https://api.openai.com/*",
        "https://openrouter.ai/*"
    ],
    "background": {
        "scripts": ["background.js"]
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ],
    "browser_action": {
        "default_title": "YouTube TLDW;",
        "default_icon": "icons/icon-48.png"
    },
    "icons": {
        "48": "icons/icon-48.png",
        "96": "icons/icon-96.png",
        "128": "icons/icon-128.png"
    },
    "web_accessible_resources": [
        "logo.png"
    ]
}
